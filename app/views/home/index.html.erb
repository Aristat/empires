<div class="home-hero">
  <h1>⚔ <%= t('nav.empires') %></h1>
  <% if user_signed_in? %>
    <p class="lead"><%= t('home.welcome_back', name: current_user.name) %></p>
  <% else %>
    <p class="lead"><%= t('home.tagline') %></p>
    <div class="mt-3">
      <%= link_to t('nav.sign_in'), new_user_session_path, class: "btn btn-primary me-2" %>
      <%= link_to t('nav.sign_up'), new_user_registration_path, class: "btn btn-outline-primary" %>
    </div>
  <% end %>
</div>

<% if user_signed_in? %>
  <h2 class="mb-3"><%= t('home.available_games') %></h2>

  <% if Game.count == 0 %>
    <div class="alert alert-info"><%= t('home.no_games') %></div>
  <% else %>
    <div class="row">
      <% Game.all.each do |game| %>
        <% user_game = current_user.user_games.find_by(game: game) %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 civ-card">
            <div class="card-header">
              <%= t('home.game_number', id: game.id) %>
            </div>
            <div class="card-body d-flex flex-column">
              <% if user_game %>
                <p class="card-text mb-1">
                  <span class="text-muted"><%= t('home.civilization') %></span>
                  <strong><%= user_game.civilization.name %></strong>
                </p>
                <p class="card-text mb-3">
                  <span class="text-muted"><%= t('home.turn') %></span>
                  <strong><%= user_game.turn %></strong>
                </p>
                <%= link_to t('home.continue_game'), game_path(game), class: "btn btn-primary mt-auto" %>
              <% else %>
                <p class="card-text text-muted mb-3"><%= t('home.not_joined') %></p>
                <%= link_to t('home.join_game'), select_civilization_game_path(game), class: "btn btn-outline-primary mt-auto" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
