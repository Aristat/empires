<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0"><%= t('aid.title') %></h5>
  </div>
  <div class="card-body">
    <% if @data[:user_data][:aid_transfer_queues].present? %>
      <div class="mb-4">
        <h6 class="text-muted mb-3"><%= t('aid.dispatched_title') %></h6>
        <% cancel_time = 15.minutes.ago %>
        <% @data[:user_data][:aid_transfer_queues].each do |transfer| %>
          <div class="card mb-2">
            <div class="card-body py-2 px-3">
              <div class="d-flex justify-content-between align-items-start gap-2">
                <div class="flex-grow-1">
                  <div class="fw-semibold mb-1">
                    <%= transfer.to_user_game.user.email %>
                    <span class="text-muted fw-normal">#<%= transfer.to_user_game.id %></span>
                  </div>
                  <div class="d-flex flex-wrap gap-1">
                    <% UserGame::AID_RESOURCES.each do |resource| %>
                      <% amount = transfer.send(resource) %>
                      <% if amount && amount > 0 %>
                        <span class="badge text-bg-secondary fw-normal">
                          <%= number_with_delimiter(amount) %> <%= resource %>
                        </span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-shrink-0">
                  <span class="badge text-bg-info">
                    <%= transfer.turns_remaining %> <%= t('aid.turns') %>
                  </span>
                  <% if transfer.turns_remaining == TransferQueue::DEFAULT_TURNS_REMAINING && transfer.created_at > cancel_time %>
                    <%= button_to t('aid.cancel_aid'),
                                  user_game_aid_path(@user_game, transfer),
                                  method: :delete,
                                  data: { confirm: t('aid.confirm_cancel') },
                                  class: "btn btn-sm btn-outline-danger" %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <p class="text-muted">
        <%= t('aid.description') %>
      </p>

      <p>
        <%= t('aid.markets_allow') %> <strong><%= number_with_delimiter(@data[:user_data][:max_trades]) %></strong> <%= t('aid.goods_each_month') %>
        <span class="<%= @data[:user_data][:trades_remaining] == 0 ? 'text-danger' : 'text-success' %>">
          <strong><%= number_with_delimiter(@data[:user_data][:trades_remaining]) %></strong>
        </span> <%= t('aid.still_available') %>
      </p>
    </div>

    <%= form_with url: user_game_aids_path(@user_game), method: :post, local: true, class: "mb-4" do |form| %>
      <div class="table-responsive">
        <table class="table table-bordered">
          <thead class="table-light">
          <tr>
            <th></th>
            <th class="text-end"><%= t('aid.table.you_have') %></th>
            <th><%= t('aid.table.send') %></th>
          </tr>
          </thead>
          <tbody>
          <% UserGame::AID_RESOURCES.each do |resource| %>
            <tr>
              <td><strong><%= resource.humanize %></strong></td>
              <td class="text-end"><%= number_with_delimiter(@user_game.send(resource)) %></td>
              <td><%= form.number_field "send_#{resource}".to_sym, min: 0, class: "form-control form-control-sm", style: "width: 120px;" %></td>
            </tr>
          <% end %>
          <tr class="table-light">
            <td colspan="2">
              <strong><%= t('aid.send_to_empire') %></strong>
              <%= form.number_field :to_user_game_id, min: 1, class: "form-control form-control-sm d-inline-block ms-2", style: "width: 80px;" %>
            </td>
            <td>
              <%= form.submit t('aid.send_btn'), class: "btn btn-primary" %>
            </td>
          </tr>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
