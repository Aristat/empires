<div class="container mt-4">
  <div class="mb-3">
    <%= link_to t('scores.back_to_game'), game_path(@game), class: 'btn btn-outline-secondary btn-sm' %>
  </div>

  <div class="card">
    <div class="card-header">
      <h5 class="mb-0"><%= t('scores.title') %></h5>
    </div>
    <div class="card-body">
      <div class="row mb-4">
        <div class="col-md-8">
          <p>
            <%= t('scores.players_in_game') %> <strong><%= @scores_data[:total_players] %></strong> <%= t('scores.players_count') %>
            <%= @scores_data[:online_players] %> <%= @scores_data[:online_players] == 1 ? t('scores.online_singular') : t('scores.online_plural') %> <%= t('scores.online_now') %>
          </p>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-header">
              <h6 class="mb-0"><%= t('scores.legend.title') %></h6>
            </div>
            <div class="card-body">
              <p class="mb-1"><span class="text-info"><%= t('scores.legend.your_empire') %></span></p>
              <p class="mb-1"><span class="text-warning"><%= t('scores.legend.protection') %></span></p>
              <p class="mb-1"><%= t('scores.legend.research_levels') %></p>
              <p class="mb-0"><%= t('scores.legend.online') %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="table-responsive">
        <table class="table table-bordered table-striped">
          <thead class="table-light">
            <tr>
              <th scope="col"><%= t('scores.table.rank') %></th>
              <th scope="col"><%= t('scores.table.player') %></th>
              <th scope="col"><%= t('scores.table.civilization') %></th>
              <th scope="col"><%= t('scores.table.research') %></th>
              <th scope="col"><%= t('scores.table.land') %></th>
              <th scope="col"><%= t('scores.table.score') %></th>
            </tr>
          </thead>
          <tbody>
            <% @scores_data[:players].each do |player| %>
              <%
                row_class = if player[:id] == @scores_data[:current_user_game_id]
                  'table-info'
                elsif player[:under_protection]
                  'table-warning'
                else
                  ''
                end
              %>
              <tr class="<%= row_class %>">
                <td><%= player[:rank] %></td>
                <td>
                  <%= "#{player[:email]} (#{player[:id]})" %>
                  <%= '*' if player[:online] %>
                  <% if player[:under_protection] %>
                    <span title="<%= t('scores.under_protection', turns: player[:protection_turns_remaining]) %>">🛡 <%= player[:protection_turns_remaining] %></span>
                  <% end %>
                </td>
                <td><%= player[:civilization] %></td>
                <td><%= player[:research_levels] %></td>
                <td><%= number_with_delimiter(player[:total_land]) %></td>
                <td><%= number_with_delimiter(player[:score]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
