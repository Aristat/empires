<div class="container-fluid mt-4">
  <!-- Game Header -->
  <div class="card game-header-card mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <span class="game-header__label">GAME #<%= @game.id %></span>
          <div class="civilization-name"><%= @user_game.civilization.name %></div>
          <div class="game-header__sub">
            <%= Date::MONTHNAMES[@month] %> <%= @year %> &mdash; <%= season(@month) %>
          </div>
        </div>
        <div class="text-end">
          <div class="game-header__label">TURNS</div>
          <div class="game-header__turns"><%= @user_game.current_turns %></div>
          <div class="game-header__label">
            <% if @user_game.current_turns >= @game.max_turns %>
              maximum stored
            <% else %>
              next in <%= @next_turn_seconds / 60 %>m <%= @next_turn_seconds % 60 %>s
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if @user_game.last_message.present? %>
    <div class="card events-card mb-4">
      <div class="card-header">Last Turn Events</div>
      <div class="card-body">
        <% @user_game.last_message.each do |message| %>
          <p class="mb-1 <%= bootstrap_text_class(message['color']) %>">
            <%= message['text'] %>
          </p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="row">
    <!-- Left Sidebar -->
    <div class="col-md-2">
      <div class="mb-3">
        <button onclick="endTurn()" class="btn btn-primary w-100">⚡ End Turn</button>
      </div>

      <!-- Tab Navigation -->
      <ul class="nav nav-pills flex-column mb-4" id="gameTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="builders-tab" data-bs-toggle="tab" data-bs-target="#builders" type="button" role="tab" aria-controls="builders" aria-selected="false">
            ⚒ Builders
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="wall-tab" data-bs-toggle="tab" data-bs-target="#wall" type="button" role="tab" aria-controls="wall" aria-selected="false">
            🏰 Wall (<%= number_with_delimiter(@data[:user_data][:wall_protection]) %>%)
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="explore-tab" data-bs-toggle="tab" data-bs-target="#explore" type="button" role="tab" aria-controls="explore" aria-selected="false">
            🗺 Explore
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="local-trade-tab" data-bs-toggle="tab" data-bs-target="#local-trade" type="button" role="tab" aria-controls="local-trade" aria-selected="false">
            ⚖ Local Trade
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="global-trade-tab" data-bs-toggle="tab" data-bs-target="#global-trade" type="button" role="tab" aria-controls="global-trade" aria-selected="false">
            🌍 Global Trade
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="research-tab" data-bs-toggle="tab" data-bs-target="#research" type="button" role="tab" aria-controls="research" aria-selected="false">
            📜 Research
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="army-tab" data-bs-toggle="tab" data-bs-target="#army" type="button" role="tab" aria-controls="army" aria-selected="false">
            ⚔ Army
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="attack-tab" data-bs-toggle="tab" data-bs-target="#attack" type="button" role="tab" aria-controls="attack" aria-selected="false">
            🗡 Attack
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="management-tab" data-bs-toggle="tab" data-bs-target="#management" type="button" role="tab" aria-controls="management" aria-selected="false">
            📋 Management
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="aid-tab" data-bs-toggle="tab" data-bs-target="#aid" type="button" role="tab" aria-controls="aid" aria-selected="false">
            🤝 Aid
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link w-100 text-start" id="scores-tab" data-bs-toggle="tab" data-bs-target="#scores" type="button" role="tab" aria-controls="scores" aria-selected="false">
            🏆 Scores
          </button>
        </li>
      </ul>
    </div>

    <!-- Main Content -->
    <div class="col-md-10">
      <!-- Summary Bar -->
      <div class="summary-bar mb-4">
        <div class="summary-bar__item">
          <span class="summary-bar__label">Score</span>
          <span class="summary-bar__value"><%= number_with_delimiter(@user_game.score) %></span>
        </div>
        <div class="summary-bar__item">
          <span class="summary-bar__label">Population</span>
          <span class="summary-bar__value"><%= number_with_delimiter(@user_game.people) %></span>
        </div>
        <div class="summary-bar__item">
          <span class="summary-bar__label">Gold</span>
          <span class="summary-bar__value"><%= number_with_delimiter(@user_game.gold) %></span>
        </div>
      </div>

      <!-- Land & Resources Overview -->
      <div class="card mb-4">
        <div class="card-body">
          <div class="row">
            <!-- Land -->
            <div class="col-md-6">
              <h6 class="text-center fw-bold mb-3">Land</h6>
              <table class="table table-sm table-borderless resource-table">
                <tbody>
                  <tr>
                    <td class="align-middle text-center p-3"><strong>Total</strong></td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('mland.gif') %>" alt="Mountain Land" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.m_land) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('fland.gif') %>" alt="Forest Land" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.f_land) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('pland.gif') %>" alt="Plains Land" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.p_land) %></span>
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td class="align-middle text-center p-3"><strong>Free</strong></td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('mland_free.gif') %>" alt="Free Mountain" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@data[:user_data][:free_mountains]) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('fland_free.gif') %>" alt="Free Forest" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@data[:user_data][:free_forest]) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('pland_free.gif') %>" alt="Free Plains" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@data[:user_data][:free_plains]) %></span>
                      </div>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            <!-- Resources -->
            <div class="col-md-6">
              <h6 class="text-center fw-bold mb-3">Resources</h6>
              <table class="table table-sm table-borderless resource-table">
                <tbody>
                  <tr>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('wood.gif') %>" alt="Wood" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.wood) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('food.gif') %>" alt="Food" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.food) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('iron.gif') %>" alt="Iron" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.iron) %></span>
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('tools.gif') %>" alt="Tools" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.tools) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('wine.gif') %>" alt="Wine" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.wine) %></span>
                      </div>
                    </td>
                    <td class="text-center p-3">
                      <div class="d-flex flex-column align-items-center">
                        <img src="<%= asset_path('horses.gif') %>" alt="Horses" class="mb-1">
                        <span class="fw-semibold"><%= number_with_delimiter(@user_game.horses) %></span>
                      </div>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab Content -->
      <div class="tab-content" id="gameTabsContent">
        <div class="tab-pane fade" id="builders" role="tabpanel" aria-labelledby="builders-tab">
          <%= render 'builders', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="wall" role="tabpanel" aria-labelledby="wall-tab">
          <%= render 'wall', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="explore" role="tabpanel" aria-labelledby="explore-tab">
          <%= render 'explore', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="local-trade" role="tabpanel" aria-labelledby="local-trade-tab">
          <%= render 'local_trade', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="global-trade" role="tabpanel" aria-labelledby="global-trade-tab">
          <%= render 'global_trade', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="research" role="tabpanel" aria-labelledby="research-tab">
          <%= render 'research', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="army" role="tabpanel" aria-labelledby="army-tab">
          <%= render 'army', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="attack" role="tabpanel" aria-labelledby="attack-tab">
          <%= render 'attack', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="management" role="tabpanel" aria-labelledby="management-tab">
          <%= render 'management', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="aid" role="tabpanel" aria-labelledby="aid-tab">
          <%= render 'aid', user_game: @user_game %>
        </div>
        <div class="tab-pane fade" id="scores" role="tabpanel" aria-labelledby="scores-tab">
          <%
            show_scores_data = {
              total_players: @data[:user_data][:users].length,
              online_players: @data[:user_data][:online_users],
              current_user_game_id: @user_game.id,
              players: @data[:user_data][:users].map { |u| u.merge(rank: u[:index] + 1) }
            }
          %>
          <%= render 'scores', scores_data: show_scores_data, show_actions: true %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function initializeActiveTab() {
  var savedTab = localStorage.getItem("activeTab_<%= @user_game.id %>") || "builders-tab";
  var tabToActivate = document.getElementById(savedTab);
  var paneId = savedTab.replace("-tab", "");
  var paneToActivate = document.getElementById(paneId);

  if (tabToActivate && paneToActivate) {
    tabToActivate.classList.add("active");
    tabToActivate.setAttribute("aria-selected", "true");
    paneToActivate.classList.add("show", "active");
  }
})();

function endTurn() {
  fetch("<%= end_turn_user_game_path(@user_game) %>", {
    method: "POST",
    headers: { "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").content }
  }).then(function (response) {
    if (response.ok) window.location.reload();
  });
}

document.addEventListener("DOMContentLoaded", function () {
  var gameTabs = document.getElementById("gameTabs");
  gameTabs.addEventListener("shown.bs.tab", function (event) {
    localStorage.setItem("activeTab_<%= @user_game.id %>", event.target.id);
  });
});
</script>
