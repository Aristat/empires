<%# Explore Tab Content %>
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0"><%= t('explore.title') %></h5>
    <%= link_to t('explore.help'), "#", class: "btn btn-sm btn-outline-secondary", data: { bs_toggle: "modal", bs_target: "#exploreHelpModal" } %>
  </div>
  <div class="card-body">
    <%= render 'explore_queues' %>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <h6 class="mb-3"><%= t('explore.status.title') %></h6>
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.status.current_explorers') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@data[:user_data][:total_explorers]) %></span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.status.maximum_explorers') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@data[:user_data][:max_explorers]) %></span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.status.available_horses') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@user_game.horses) %></span>
              </li>
            </ul>
          </div>
          <div class="col-md-6">
            <h6 class="mb-3"><%= t('explore.requirements.title') %></h6>
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.requirements.food_per_explorer') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@data[:user_data][:food_per_explorer]) %></span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.requirements.can_send_food') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@data[:user_data][:send_explorers]) %></span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= t('explore.requirements.can_send_total') %></span>
                <span class="badge bg-primary rounded-pill"><%= number_with_delimiter(@data[:user_data][:can_send_explorers]) %></span>
              </li>
            </ul>
          </div>
        </div>

        <% if @data[:user_data][:efficiency_of_explore] < 100 %>
          <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <%= t('explore.efficiency_warning', efficiency: @data[:user_data][:efficiency_of_explore]) %>
          </div>
        <% end %>
      </div>
    </div>

    <%= form_with url: user_game_explore_queues_path(@user_game), method: :post, local: true, class: "mt-4" do |f| %>
      <div class="card">
        <div class="card-body">
          <div class="row align-items-end">
            <div class="col-md-3">
              <div class="mb-3">
                <%= f.label :quantity, t('explore.send_explorers_label'), class: "form-label" %>
                <%= f.number_field :quantity,
                    value: @data[:user_data][:can_send_explorers],
                    class: "form-control",
                    min: 1,
                    max: @data[:user_data][:can_send_explorers] %>
              </div>
            </div>

            <div class="col-md-3">
              <div class="mb-3">
                <%= f.label :horse_setting, t('explore.with_horses'), class: "form-label" %>
                <%= f.select :horse_setting,
                    options_for_select([
                      [t('explore.horse_options.no_horses'), 'without_horses'],
                      [t('explore.horse_options.one_horse'), 'one_horse'],
                      [t('explore.horse_options.two_horses'), 'two_horses'],
                      [t('explore.horse_options.three_horses'), 'three_horses']
                    ]),
                    {},
                    class: "form-select",
                    data: { explore_setting: "horse" } %>
              </div>
            </div>

            <div class="col-md-3">
              <div class="mb-3">
                <%= f.label :seek_land, t('explore.look_for'), class: "form-label" %>
                <%= f.select :seek_land,
                    options_for_select([
                      [t('explore.land_options.all_land'), 'all_land'],
                      [t('explore.land_options.mountain_land'), 'mountain_land'],
                      [t('explore.land_options.forest_land'), 'forest_land'],
                      [t('explore.land_options.plain_land'), 'plain_land']
                    ]),
                    {},
                    class: "form-select",
                    data: { explore_setting: "land" } %>
              </div>
            </div>

            <div class="col-md-3">
              <%= f.submit t('explore.send_btn'), class: "btn btn-primary w-100" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Explore Help Modal %>
<div class="modal fade" id="exploreHelpModal" tabindex="-1" aria-labelledby="exploreHelpModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exploreHelpModalLabel"><%= t('explore.help_modal.title') %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p><%= t('explore.help_modal.description') %></p>

        <h6><%= t('explore.help_modal.horse_multiplier') %></h6>
        <ul>
          <li><%= t('explore.help_modal.no_horses_base') %></li>
          <li><%= t('explore.help_modal.one_horse_2x') %></li>
          <li><%= t('explore.help_modal.two_horses_3x') %></li>
          <li><%= t('explore.help_modal.three_horses_4x') %></li>
        </ul>

        <h6><%= t('explore.help_modal.land_types') %></h6>
        <ul>
          <li><%= t('explore.help_modal.all_land_equal') %></li>
          <li><%= t('explore.help_modal.mountain_focus') %></li>
          <li><%= t('explore.help_modal.forest_focus') %></li>
          <li><%= t('explore.help_modal.plains_focus') %></li>
        </ul>

        <div class="alert alert-info mt-3">
          <strong><%= t('explore.help_modal.tip_label') %></strong> <%= t('explore.help_modal.tip') %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= t('explore.help_modal.close') %></button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const storedHorseSetting = localStorage.getItem('exploreHorseSetting_<%= @user_game.id %>') || 'without_horses';
    const storedLandSetting = localStorage.getItem('exploreLandSetting_<%= @user_game.id %>') || 'all_land';

    function initializeSelects() {
      const horseSelect = document.querySelector('[data-explore-setting="horse"]');
      const landSelect = document.querySelector('[data-explore-setting="land"]');

      if (horseSelect && landSelect) {
        horseSelect.value = storedHorseSetting;
        landSelect.value = storedLandSetting;
      }
    }

    initializeSelects();

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-explore-setting]').forEach(select => {
        select.addEventListener('change', function() {
          const setting = this.dataset.exploreSetting;
          localStorage.setItem(`explore${setting.charAt(0).toUpperCase() + setting.slice(1)}Setting_<%= @user_game.id %>`, this.value);
        });
      });
    });
  })();
</script>
