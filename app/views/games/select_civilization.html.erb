<div class="container mt-4">
  <h1 class="mb-1"><%= t('select_civilization.title') %></h1>
  <p class="lead text-muted mb-4"><%= t('select_civilization.subtitle', id: @game.id) %></p>

  <div class="row">
    <% @civilizations.each do |civilization| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 civ-card">
          <div class="card-header">
            <%= civilization.name %>
          </div>
          <div class="card-body d-flex flex-column">
            <p class="card-text text-muted mb-3"><%= civilization.description %></p>

            <% if civilization.buildings.present? %>
              <h6 class="mb-2"><%= t('select_civilization.bonuses') %></h6>
              <ul class="list-unstyled mb-3">
                <% civilization.buildings.to_a.each do |key, value| %>
                  <li class="mb-1">
                    <%= key.humanize %>:
                    <% if value.present? %>
                      <span class="civ-bonus-positive">+<%= value %>%</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>

            <%= button_to t('select_civilization.choose', name: civilization.name),
                          join_game_path(@game, civilization_id: civilization.id),
                          method: :post,
                          class: "btn btn-primary w-100 mt-auto" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
