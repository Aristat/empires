<div class="auth-wrapper">
  <div class="auth-card">
    <h2>Forgot Password?</h2>
    <p class="text-muted" style="font-size: 0.875rem;">Enter your email and we'll send reset instructions.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control mt-1" %>
      </div>

      <div class="actions">
        <%= f.submit "Send Reset Instructions", class: "btn btn-primary w-100" %>
      </div>
    <% end %>

    <div class="devise-links mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
