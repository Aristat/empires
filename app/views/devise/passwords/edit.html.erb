<div class="auth-wrapper">
  <div class="auth-card">
    <h2>Change Password</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="field">
        <%= f.label :password, "New Password" %>
        <% if @minimum_password_length %>
          <em class="text-muted" style="font-size: 0.8rem;">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control mt-1" %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "Confirm New Password" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control mt-1" %>
      </div>

      <div class="actions">
        <%= f.submit "Change Password", class: "btn btn-primary w-100" %>
      </div>
    <% end %>

    <div class="devise-links mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
