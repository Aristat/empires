<div class="auth-wrapper">
  <div class="auth-card">
    <h2>Edit Profile</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control mt-1" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="alert alert-info mt-2">
          Awaiting confirmation for: <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :password %>
        <em class="text-muted" style="font-size: 0.8rem;">(leave blank to keep current)</em>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control mt-1" %>
        <% if @minimum_password_length %>
          <small class="text-muted"><%= @minimum_password_length %> characters minimum</small>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control mt-1" %>
      </div>

      <div class="field">
        <%= f.label :current_password %>
        <em class="text-muted" style="font-size: 0.8rem;">(required to confirm changes)</em>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control mt-1" %>
      </div>

      <div class="actions">
        <%= f.submit "Update Profile", class: "btn btn-primary w-100" %>
      </div>
    <% end %>

    <hr style="border-color: var(--border-color);">

    <h3 style="font-size: 1rem; color: var(--accent-red);">Danger Zone</h3>
    <p class="text-muted" style="font-size: 0.875rem;">This will permanently delete your account.</p>
    <%= button_to "Cancel my account",
                  registration_path(resource_name),
                  data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                  method: :delete,
                  class: "btn btn-danger w-100" %>

    <div class="devise-links mt-3">
      <%= link_to "← Back", :back %>
    </div>
  </div>
</div>
