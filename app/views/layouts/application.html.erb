<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Empires" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%# Apply theme before body renders to prevent flash of unstyled content %>
    <script>
      (function () {
        var theme = localStorage.getItem("empires_theme") || "dark";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body>
    <header class="navbar-header">
      <div class="navbar-inner">
        <%= link_to root_path, class: "navbar-brand" do %>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M3 20h18M5 20V9l4 3 3-6 3 6 4-3v11" />
          </svg>
          <span>Empires</span>
        <% end %>
        <div class="navbar-actions">
          <button id="theme-toggle" class="navbar-icon-btn" aria-label="Toggle theme">
            <svg id="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
            </svg>
            <svg id="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
            </svg>
          </button>
          <button class="navbar-icon-btn" id="navbar-menu-btn" aria-label="Open menu" aria-expanded="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <div class="navbar-dropdown" id="navbar-dropdown" hidden>
            <% if user_signed_in? %>
              <%= link_to "Back to Games", root_path, class: "navbar-dropdown-item" %>
              <%= link_to "Edit Profile", edit_user_registration_path, class: "navbar-dropdown-item" %>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "navbar-dropdown-item", form_class: "navbar-dropdown-form" %>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "navbar-dropdown-item" %>
              <%= link_to "Sign Up", new_user_registration_path, class: "navbar-dropdown-item" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <div class="<%= content_for?(:container_class) ? yield(:container_class) : 'container' %> mt-3">
      <% if flash[:notice] %>
        <div class="alert alert-success alert-dismissible" role="alert">
          <%= flash[:notice] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="alert alert-danger alert-dismissible" role="alert">
          <%= flash[:alert] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </body>
</html>
