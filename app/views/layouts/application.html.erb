<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Empires" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%# Apply theme before body renders to prevent flash of unstyled content %>
    <script>
      (function () {
        var theme = localStorage.getItem("empires_theme") || "dark";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body>
    <nav class="navbar">
      <%= link_to "⚔ Empires", root_path, class: "navbar-brand" %>
      <div class="navbar-menu" id="navbar-menu-wrapper">
        <button class="navbar-menu-btn" id="navbar-menu-btn" aria-label="Open menu" aria-expanded="false">☰</button>
        <div class="navbar-dropdown" id="navbar-dropdown" hidden>
          <button class="navbar-dropdown-item" id="theme-toggle" aria-label="Toggle theme">🌙 Theme</button>
          <% if user_signed_in? %>
            <%= link_to "Back to Games", root_path, class: "navbar-dropdown-item" %>
            <%= link_to "Edit Profile", edit_user_registration_path, class: "navbar-dropdown-item" %>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "navbar-dropdown-item", form_class: "navbar-dropdown-form" %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "navbar-dropdown-item" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "navbar-dropdown-item" %>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="<%= content_for?(:container_class) ? yield(:container_class) : 'container' %> mt-3">
      <% if flash[:notice] %>
        <div class="alert alert-success alert-dismissible" role="alert">
          <%= flash[:notice] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="alert alert-danger alert-dismissible" role="alert">
          <%= flash[:alert] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </body>
</html>
