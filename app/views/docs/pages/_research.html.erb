<h2><%= t('docs.pages.research.title') %></h2>

<p><%= t('docs.pages.research.intro_html',
         production: @buildings['mage_tower']&.production&.to_f || 1,
         gold: @buildings['mage_tower']&.settings&.dig('research_gold_need') || 100) %></p>

<h4><%= t('docs.pages.research.cost_formula.heading') %></h4>
<p><%= t('docs.pages.research.cost_formula.desc') %></p>
<p><code><%= t('docs.pages.research.cost_formula.formula') %></code></p>
<p><%= t('docs.pages.research.cost_formula.note') %></p>

