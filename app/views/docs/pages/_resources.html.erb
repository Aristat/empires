<table class="table table-bordered">
  <thead>
    <tr>
      <th style="width:10%">Resource</th>
      <th style="width:30%">Produced By</th>
      <th style="width:30%">Used For</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    <% resources.each do |r| %>
      <tr>
        <td><strong><%= r[:name] %></strong></td>
        <td><%= r[:produced_by] %></td>
        <td><%= r[:used_for] %></td>
        <td class="text-secondary"><small><%= r[:notes] %></small></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h4>Storage Limits</h4>
<p>
  Resources are capped by your storage capacity. Each <strong>Town Center</strong> provides
  <%= @buildings['town_center']&.settings&.dig('resources_limit_increase') || 1000 %> storage.
  Each <strong>Warehouse</strong> provides
  <%= @buildings['warehouse']&.settings&.dig('resources_limit_increase') || 2500 %> storage.
  The <em>Space Effectiveness</em> research increases storage by 1% per level.
  Resources over the cap are lost at the end of each turn.
</p>

<h4>Weaponsmith Production</h4>
<p>
  Each Weaponsmith can produce one type of weapon per turn. Set the production mix on the
  Management screen. Costs per weapon for this game:
</p>
<% ws = @buildings['weaponsmith'] %>
<% if ws %>
  <ul>
    <li>1 Bow = <%= ws.settings['bow_wood_need'] || 25 %> wood</li>
    <li>1 Sword = <%= ws.settings['sword_iron_need'] || 25 %> iron</li>
    <li>1 Mace = <%= ws.settings['mace_wood_need'] || 6 %> wood + <%= ws.settings['mace_iron_need'] || 6 %> iron</li>
  </ul>
<% end %>
