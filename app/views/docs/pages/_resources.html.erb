<h2>Resources</h2>

<p>Resources are produced by buildings each turn and consumed by population, army, and construction.</p>

<% resources = [
  {
    key: 'gold',
    name: 'Gold',
    produced_by: 'Gold Mines, Local/Global Market sales',
    used_for: 'Building construction, army upkeep, research, training soldiers',
    notes: 'The main currency. Running out of gold causes soldiers to desert.'
  },
  {
    key: 'food',
    name: 'Food',
    produced_by: 'Farms (months 4–10 only), Hunters (year-round)',
    used_for: 'Feeding population and army, sending explorers',
    notes: 'If food runs out, population starves. Farms do not produce in winter.'
  },
  {
    key: 'wood',
    name: 'Wood',
    produced_by: 'Wood Cutters',
    used_for: 'Building construction, bows, maces, tools, heating in winter, wall construction, catapult upkeep',
