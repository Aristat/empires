<h2>Buildings</h2>

<p>
  Buildings are constructed by builders (provided by Tool Makers) using wood, iron, and gold.
  Each building occupies a certain number of land squares of a specific type.
  Base stats are shown below — your civilization may modify some values
  (see <%= link_to "Civilizations", game_docs_path(@game, page: 'civs') %>).
</p>

<% land_labels = { 'forest' => 'Forest', 'plain' => 'Plain', 'mountain' => 'Mountain' } %>

<h4>Production Buildings</h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>Building</th>
      <th class="text-center">Land</th>
      <th class="text-center">Squares</th>
      <th class="text-center">Workers</th>
      <th class="text-center">Cost (W/I/G)</th>
      <th class="text-center">Production</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    <% %w[hunter farm wood_cutter iron_mine gold_mine winery tool_maker weaponsmith stable mage_tower].each do |key| %>
      <% b = @buildings[key] %>
      <% next unless b %>
      <%
        land      = land_labels[b.land.to_s] || b.land.to_s.capitalize
        prod      = b.production.to_f
        prod_name = b.settings['production_name'] || ''
      %>
      <tr>
        <td><strong><%= b.name %></strong></td>
        <td class="text-center"><%= land %></td>
        <td class="text-center"><%= b.squares.to_i %></td>
        <td class="text-center"><%= b.workers.to_i %></td>
        <td class="text-center"><%= b.cost_wood.to_i %>/<%= b.cost_iron.to_i %>/<%= b.cost_gold.to_i %></td>
        <td class="text-center">
          <% if prod > 0 %>
            <%= prod == prod.to_i ? prod.to_i : prod %> <%= prod_name %>
          <% end %>
          <% if key == 'tool_maker' %>
            <br><small class="text-secondary">needs <%= b.settings['tool_wood_need'] || 2 %>W + <%= b.settings['tool_iron_need'] || 2 %>I per tool</small>
          <% elsif key == 'winery' %>
            <br><small class="text-secondary">needs <%= b.settings['wine_gold_need'] || 10 %> gold per wine</small>
          <% elsif key == 'stable' %>
            <br><small class="text-secondary">needs <%= b.settings['food_need'] || 100 %> food per horse</small>
          <% elsif key == 'mage_tower' %>
            <br><small class="text-secondary">needs <%= b.settings['research_gold_need'] || 100 %> gold/tower</small>
          <% end %>
        </td>
        <td>
          <% if key == 'tool_maker' %>
            Provides <%= b.settings['num_builders'] || 6 %> builders
          <% elsif key == 'weaponsmith' %>
            Bow: <%= b.settings['bow_wood_need'] || 25 %>W &middot; Sword: <%= b.settings['sword_iron_need'] || 25 %>I &middot; Mace: <%= b.settings['mace_wood_need'] || 6 %>W+<%= b.settings['mace_iron_need'] || 6 %>I
          <% elsif key == 'mage_tower' %>
            Generates research points
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h4>Military &amp; Infrastructure</h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>Building</th>
      <th class="text-center">Land</th>
      <th class="text-center">Squares</th>
      <th class="text-center">Cost (W/I/G)</th>
      <th>Special</th>
    </tr>
  </thead>
  <tbody>
    <% %w[fort tower town_center market warehouse house].each do |key| %>
      <% b = @buildings[key] %>
      <% next unless b %>
      <tr>
        <td><strong><%= b.name %></strong></td>
        <td class="text-center"><%= land_labels[b.land.to_s] || b.land.to_s.capitalize %></td>
        <td class="text-center"><%= b.squares.to_i %></td>
        <td class="text-center"><%= b.cost_wood.to_i %>/<%= b.cost_iron.to_i %>/<%= b.cost_gold.to_i %></td>
        <td>
          <% if key == 'fort' %>
            Trains up to <%= b.settings['max_units'] || 15 %> units; food upkeep: <%= b.food_eaten.to_i %>/turn
          <% elsif key == 'tower' %>
            Defense: <%= b.settings['defense_points'] || 50 %> pts (no upkeep)
          <% elsif key == 'town_center' %>
            +<%= b.people.to_i %> population cap;
            <%= b.settings['resources_limit_increase'] || 1000 %> storage;
            <%= b.settings['max_explorers'] || 6 %> max explorers;
            1 thief + 1 catapult + 1 special unit slot
          <% elsif key == 'market' %>
            +<%= b.settings['max_trades'] || 50 %> local trades/turn
          <% elsif key == 'warehouse' %>
            +<%= b.settings['resources_limit_increase'] || 2500 %> storage
          <% elsif key == 'house' %>
            +<%= b.people.to_i %> population cap; food upkeep: <%= b.food_eaten.to_i %>/turn
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="alert alert-secondary mt-3">
  <strong>Cost = W/I/G</strong> — Wood / Iron / Gold to construct one building.<br>
  <strong>Squares</strong> — land squares of that type used per building.<br>
  Civilization bonuses may change squares, production, workers, or other values — see
  <%= link_to "Civilizations", game_docs_path(@game, page: 'civs') %> for details.
</div>

<h4>Builders</h4>
<p>
  Each Tool Maker provides <%= @buildings['tool_maker']&.settings&.dig('num_builders') || 6 %> builders,
  plus <%= Building::DEFAULT_NUM_BUILDERS %> default builders at the start.
  Builders require one tool each to work.
  Building construction time (in builder-turns) equals the sum of the building's wood and iron costs.
</p>
