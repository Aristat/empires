<h2><%= t('docs.pages.army.title') %></h2>

<p><%= t('docs.pages.army.intro_html', civs_link: link_to(t('docs.nav.civs'), game_docs_path(@game, page: 'civs'))) %></p>

<% def fmt_num(v)
     return '' if v.nil?
     f = v.to_f
     f == f.to_i ? f.to_i.to_s : f.to_s
   end
%>

<h4><%= t('docs.pages.army.standard_heading') %></h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th><%= t('docs.pages.army.table.unit') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.trains_in') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.attack') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.defense') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.upkeep') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.required') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.land_taken') %></th>
    </tr>
  </thead>
  <tbody>
    <% %w[swordsman archer horseman macemen trained_peasant].each do |key| %>
      <% s = @soldiers[key] %>
      <% next unless s %>
      <%
        train_parts = []
        train_parts << "#{s.train_swords.to_i} sword"  if s.train_swords.to_i > 0
        train_parts << "#{s.train_bows.to_i} bow"      if s.train_bows.to_i > 0
        train_parts << "#{s.train_maces.to_i} mace"    if s.train_maces.to_i > 0
        train_parts << "#{s.train_horses.to_i} horse"  if s.train_horses.to_i > 0
        train_parts << "#{s.train_gold.to_i} gold"     if s.train_gold.to_i > 0
        train_str = train_parts.any? ? train_parts.join(', ') : 'nothing'
      %>
      <tr>
        <td><strong><%= s.name %></strong></td>
        <td class="text-center"><%= s.turns.to_i %> <%= t('docs.pages.army.turns_unit') %></td>
        <td class="text-center"><%= fmt_num(s.attack_points) %></td>
        <td class="text-center"><%= fmt_num(s.defense_points) %></td>
        <td class="text-center"><%= fmt_num(s.gold_per_turn) %> <%= t('docs.pages.army.gold_unit') %><br><%= fmt_num(s.food_eaten) %> <%= t('docs.pages.army.food_unit') %></td>
        <td class="text-center"><%= train_str %></td>
        <td class="text-center"><%= fmt_num(s.take_land) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h4><%= t('docs.pages.army.special_heading') %></h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th><%= t('docs.pages.army.table.unit') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.trains_in') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.attack') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.defense') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.upkeep') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.required') %></th>
      <th class="text-center"><%= t('docs.pages.army.table.land_taken') %></th>
    </tr>
  </thead>
  <tbody>
    <% %w[unique_unit catapult thieve tower].each do |key| %>
      <% s = @soldiers[key] %>
      <% next unless s %>
      <%
        wood_pt = s.settings['wood_per_turn'].to_f
        iron_pt = s.settings['iron_per_turn'].to_f

        train_parts = []
        train_parts << "#{s.train_swords.to_i} sword"  if s.train_swords.to_i > 0
        train_parts << "#{s.train_bows.to_i} bow"      if s.train_bows.to_i > 0
        train_parts << "#{s.train_maces.to_i} mace"    if s.train_maces.to_i > 0
        train_parts << "#{s.train_horses.to_i} horse"  if s.train_horses.to_i > 0
        train_parts << "#{s.train_gold.to_i} gold"     if s.train_gold.to_i > 0
        train_parts << "#{s.train_wood.to_i} wood"     if s.train_wood.to_i > 0
        train_parts << "#{s.train_iron.to_i} iron"     if s.train_iron.to_i > 0
        train_str = train_parts.any? ? train_parts.join(', ') : 'nothing'
      %>
      <tr>
        <td>
          <strong><%= key == 'unique_unit' ? t('docs.pages.army.special_unit_label') : s.name %></strong>
          <% if key == 'unique_unit' %>
            <br><small class="text-secondary"><%= t('docs.pages.army.vary_by_civ') %></small>
          <% end %>
        </td>
        <td class="text-center">
          <% if key == 'tower' %><%= t('docs.pages.army.permanent') %>
          <% elsif s.turns.to_i == -1 %>—
          <% else %><%= s.turns.to_i %> <%= t('docs.pages.army.turns_unit') %>
          <% end %>
        </td>
        <td class="text-center"><%= fmt_num(s.attack_points) %></td>
        <td class="text-center"><%= fmt_num(s.defense_points) %></td>
        <td class="text-center">
          <%= fmt_num(s.gold_per_turn) %> <%= t('docs.pages.army.gold_unit') %><br>
          <%= fmt_num(s.food_eaten) %> <%= t('docs.pages.army.food_unit') %>
          <% if wood_pt > 0 %><br><%= fmt_num(wood_pt) %> <%= t('docs.pages.army.wood_unit') %><% end %>
          <% if iron_pt > 0 %><br><%= fmt_num(iron_pt) %> <%= t('docs.pages.army.iron_unit') %><% end %>
        </td>
        <td class="text-center"><%= train_str %></td>
        <td class="text-center"><%= fmt_num(s.take_land) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="alert alert-secondary">
  <%= t('docs.pages.army.notes_html') %>
</div>

<h4><%= t('docs.pages.army.capacity.heading') %></h4>
<p><%= t('docs.pages.army.capacity.desc_html',
         fort_units: @buildings['fort']&.settings&.dig('max_units') || 15,
         tc_units: @buildings['town_center']&.settings&.dig('max_units') || 10) %></p>
