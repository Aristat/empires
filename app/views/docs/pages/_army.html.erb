<h2>Army Units</h2>

<p>
  Base stats for all units are shown below. Civilizations may modify attack/defense points,
  training turns, or training costs for certain units — see
  <%= link_to "Civilizations", game_docs_path(@game, page: 'civs') %>.
</p>

<% def fmt_num(v)
     return '' if v.nil?
     f = v.to_f
     f == f.to_i ? f.to_i.to_s : f.to_s
   end
%>

<h4>Standard Units</h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>Unit</th>
      <th class="text-center">Trains in</th>
      <th class="text-center">Attack</th>
      <th class="text-center">Defense</th>
      <th class="text-center">Upkeep/turn</th>
      <th class="text-center">Required to Train</th>
      <th class="text-center">Land Taken</th>
    </tr>
  </thead>
  <tbody>
    <% %w[swordsman archer horseman macemen trained_peasant].each do |key| %>
      <% s = @soldiers[key] %>
      <% next unless s %>
      <%
        train_parts = []
        train_parts << "#{s.train_swords.to_i} sword"  if s.train_swords.to_i > 0
        train_parts << "#{s.train_bows.to_i} bow"      if s.train_bows.to_i > 0
        train_parts << "#{s.train_maces.to_i} mace"    if s.train_maces.to_i > 0
        train_parts << "#{s.train_horses.to_i} horse"  if s.train_horses.to_i > 0
        train_parts << "#{s.train_gold.to_i} gold"     if s.train_gold.to_i > 0
        train_str = train_parts.any? ? train_parts.join(', ') : 'nothing'
      %>
      <tr>
        <td><strong><%= s.name %></strong></td>
        <td class="text-center"><%= s.turns.to_i %> turns</td>
        <td class="text-center"><%= fmt_num(s.attack_points) %></td>
        <td class="text-center"><%= fmt_num(s.defense_points) %></td>
        <td class="text-center"><%= fmt_num(s.gold_per_turn) %> gold<br><%= fmt_num(s.food_eaten) %> food</td>
        <td class="text-center"><%= train_str %></td>
        <td class="text-center"><%= fmt_num(s.take_land) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h4>Special Units (1 per Town Center)</h4>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>Unit</th>
      <th class="text-center">Trains in</th>
      <th class="text-center">Attack</th>
      <th class="text-center">Defense</th>
      <th class="text-center">Upkeep/turn</th>
      <th class="text-center">Required to Train</th>
      <th class="text-center">Land Taken</th>
    </tr>
  </thead>
  <tbody>
    <% %w[unique_unit catapult thieve tower].each do |key| %>
      <% s = @soldiers[key] %>
      <% next unless s %>
      <%
        wood_pt = s.settings['wood_per_turn'].to_f
        iron_pt = s.settings['iron_per_turn'].to_f

        train_parts = []
        train_parts << "#{s.train_swords.to_i} sword"  if s.train_swords.to_i > 0
        train_parts << "#{s.train_bows.to_i} bow"      if s.train_bows.to_i > 0
        train_parts << "#{s.train_maces.to_i} mace"    if s.train_maces.to_i > 0
        train_parts << "#{s.train_horses.to_i} horse"  if s.train_horses.to_i > 0
        train_parts << "#{s.train_gold.to_i} gold"     if s.train_gold.to_i > 0
        train_parts << "#{s.train_wood.to_i} wood"     if s.train_wood.to_i > 0
        train_parts << "#{s.train_iron.to_i} iron"     if s.train_iron.to_i > 0
        train_str = train_parts.any? ? train_parts.join(', ') : 'nothing'
      %>
      <tr>
        <td>
          <strong><%= key == 'unique_unit' ? 'Special Unit' : s.name %></strong>
          <% if key == 'unique_unit' %>
            <br><small class="text-secondary">name &amp; stats vary by civilization</small>
          <% end %>
        </td>
        <td class="text-center">
          <% if key == 'tower' %>permanent
          <% elsif s.turns.to_i == -1 %>—
          <% else %><%= s.turns.to_i %> turns
          <% end %>
        </td>
        <td class="text-center"><%= fmt_num(s.attack_points) %></td>
        <td class="text-center"><%= fmt_num(s.defense_points) %></td>
        <td class="text-center">
          <%= fmt_num(s.gold_per_turn) %> gold<br>
          <%= fmt_num(s.food_eaten) %> food
          <% if wood_pt > 0 %><br><%= fmt_num(wood_pt) %> wood<% end %>
          <% if iron_pt > 0 %><br><%= fmt_num(iron_pt) %> iron<% end %>
        </td>
        <td class="text-center"><%= train_str %></td>
        <td class="text-center"><%= fmt_num(s.take_land) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="alert alert-secondary">
  <strong>Land Taken</strong> — land conquered per unit when winning an army attack.<br>
  <strong>Special Units</strong> — Catapult, Thief, and Special Unit are limited to 1 per Town Center.<br>
  <strong>Tower</strong> — defense-only structure, cannot attack; no upkeep cost.<br>
  <strong>Catapult upkeep</strong> is paid in wood and iron, not gold.
</div>

<h4>Army Capacity</h4>
<p>
  Forts hold <%= @buildings['fort']&.settings&.dig('max_units') || 15 %> units each.
  Town Centers hold <%= @buildings['town_center']&.settings&.dig('max_units') || 10 %> units each.
  Soldiers over capacity desert at <strong>25% of the excess per turn</strong>.
  Soldiers who cannot be paid their gold upkeep also desert (10% of the unpaid amount).
</p>
